{
  "name": "synccode-backend",
  "version": "1.0.0",
  "description": "Production-ready REST API backend for SyncCode – Realtime Collaborative Code Editor",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "nodemon server.js",
    "demo":       "node demo-server.js",
    "seed":       "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset",
    "test":       "jest --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --runInBand",
    "lint":       "eslint src/**/*.js"
  },
  "keywords": ["collaborative", "code-editor", "rest-api", "jwt", "mongodb"],
  "author": "SyncCode Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": null,
    "setupFiles": ["./tests/setup.js"],
    "testTimeout": 30000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
