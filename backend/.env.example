# ============================================================
# SyncCode Backend – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=5003

# ---- MongoDB ----
# Local example:   mongodb://127.0.0.1:27017/synccode
# Atlas example:   mongodb+srv://user:pass@cluster.mongodb.net/synccode
MONGODB_URI=mongodb://127.0.0.1:27017/synccode
MONGODB_DB=synccode

# ---- JWT ----
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_secure_random_secret_min_64_chars
JWT_REFRESH_SECRET=replace_with_a_different_secure_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5001

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Logging ----
# error | warn | info | http | debug
LOG_LEVEL=info
LOG_DIR=logs
